# =============================================================================
# Hummingbot Connector E2E Test Configuration
# =============================================================================
# Copy this file to  test/e2e_tests/.env  and fill in your values.
#
# HOW IT WORKS
# ────────────
# • Set  TEST_{NAME}=true   to enable an exchange for testing.
# • Set  TEST_{NAME}=false  (or omit) to skip it.
# • Credentials use the prefix  {NAME}_CRED_{exact_param_name}=value
#   where {exact_param_name} is the connector's constructor parameter name.
#   (See the blocks below for the correct names per exchange.)
# • All non-credential settings have sensible defaults.
#
# ADDING A NEW EXCHANGE
# ─────────────────────
# 1. Add  TEST_{KEY}=true
# 2. Add  {KEY}_CONNECTOR_NAME=<hummingbot connector id>
# 3. Add  {KEY}_CRED_{param}=<value>  for each credential field
#    (find param names in hummingbot/connector/exchange/{name}/{name}_utils.py)
# 4. Optionally override TRADING_PAIR, amounts, price offsets.
# =============================================================================


# ─── Global timing (seconds) ──────────────────────────────────────────────────
# Max seconds to wait for a newly placed order to appear in in_flight_orders
ORDER_PROPAGATION_WAIT=40

# Max seconds to wait for a cancelled order to leave in_flight_orders
CANCEL_PROPAGATION_WAIT=40

# Max seconds to wait for connector.ready after start_network()
CONNECTOR_READY_TIMEOUT=20


# =============================================================================
# Exchange blocks
# Each block has the same shape. Copy/paste to add a new exchange.
# =============================================================================


# ─── WazirX ───────────────────────────────────────────────────────────────────
TEST_WAZIRX=false

WAZIRX_CONNECTOR_NAME=wazirx
WAZIRX_TRADING_PAIR=BTC-INR
WAZIRX_LIMIT_BUY_AMOUNT=0.00001
WAZIRX_LIMIT_SELL_AMOUNT=0.00001
WAZIRX_BUY_PRICE_OFFSET=0.80
WAZIRX_SELL_PRICE_OFFSET=1.20
WAZIRX_EDIT_PRICE_MULTIPLIER=0.78

# Credentials — param names from Wazirx
WAZIRX_CRED_wazirx_api_key=YOUR_API_KEY
WAZIRX_CRED_wazirx_api_secret=YOUR_API_SECRET


# ─── CoinSwitch ───────────────────────────────────────────────────────────────────
TEST_COINSWITCH=false

COINSWITCH_CONNECTOR_NAME=coinswitch
COINSWITCH_TRADING_PAIR=BTC-INR
COINSWITCH_LIMIT_BUY_AMOUNT=0.00004
COINSWITCH_LIMIT_SELL_AMOUNT=0.00004
COINSWITCH_BUY_PRICE_OFFSET=0.80
COINSWITCH_SELL_PRICE_OFFSET=1.20
COINSWITCH_EDIT_PRICE_MULTIPLIER=0.78

# Credentials — param names from Coinswitch
COINSWITCH_CRED_coinswitch_api_key=YOUR_API_KEY
COINSWITCH_CRED_coinswitch_api_secret=YOUR_API_SECRET


# ─── CoinDCX ───────────────────────────────────────────────────────────────────
TEST_COINDCX=false

COINDCX_CONNECTOR_NAME=coindcx
COINDCX_TRADING_PAIR=BTC-INR
COINDCX_LIMIT_BUY_AMOUNT=0.00002
COINDCX_LIMIT_SELL_AMOUNT=0.00002
COINDCX_BUY_PRICE_OFFSET=0.80
COINDCX_SELL_PRICE_OFFSET=1.20
COINDCX_EDIT_PRICE_MULTIPLIER=0.78

# Credentials — param names from CoinDCX
COINDCX_CRED_coindcx_api_key=YOUR_API_KEY
COINDCX_CRED_coindcx_api_secret=YOUR_API_SECRET
